---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import BriefingCard from "../components/BriefingCard.astro";
import ChannelFilter from "../components/ChannelFilter.astro";
import EmptyState from "../components/EmptyState.astro";

type BriefingEntry = CollectionEntry<"briefing">;

const allBriefings = await getCollection("briefing");
allBriefings.sort(
  (a: BriefingEntry, b: BriefingEntry) =>
    b.data.published_at.getTime() - a.data.published_at.getTime(),
);

function toKstDateStr(date: Date): string {
  const kstMs = date.getTime() + 9 * 60 * 60 * 1000;
  const k = new Date(kstMs);
  const y = k.getUTCFullYear();
  const m = String(k.getUTCMonth() + 1).padStart(2, "0");
  const d = String(k.getUTCDate()).padStart(2, "0");
  return `${y}.${m}.${d}`;
}

function toKstWeekday(date: Date): string {
  const kstMs = date.getTime() + 9 * 60 * 60 * 1000;
  const k = new Date(kstMs);
  const days = ["일", "월", "화", "수", "목", "금", "토"];
  return days[k.getUTCDay()] ?? "";
}

interface DateGroup {
  dateStr: string;
  weekday: string;
  briefings: BriefingEntry[];
}

const dateGroups: DateGroup[] = [];
let currentDate = "";
for (const b of allBriefings) {
  const ds = toKstDateStr(b.data.published_at);
  if (ds !== currentDate) {
    currentDate = ds;
    dateGroups.push({ dateStr: ds, weekday: toKstWeekday(b.data.published_at), briefings: [] });
  }
  dateGroups[dateGroups.length - 1].briefings.push(b);
}

const channelOrder = [
  { slug: "mer", name: "메르(블로그)" },
  { slug: "parkjonghoon", name: "박종훈" },
  { slug: "shuka", name: "슈카월드" },
  { slug: "understanding", name: "언더스탠딩" },
  { slug: "jisik-inside", name: "지식인사이드" },
  { slug: "globelab", name: "지구본연구소" },
  { slug: "mernote", name: "메르노트" },
  { slug: "usstock-eddie", name: "미국주식 에디" },
];

const presentSlugs = new Set(allBriefings.map((b: BriefingEntry) => b.data.channel_slug));
const zeroCountSlugs = channelOrder.map((c) => c.slug).filter((slug) => !presentSlugs.has(slug));

function isoWeekNumber(date: Date): string {
  const target = new Date(Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate()));
  const dayNr = (target.getUTCDay() + 6) % 7;
  target.setUTCDate(target.getUTCDate() - dayNr + 3);
  const firstThursday = target.valueOf();
  target.setUTCMonth(0, 1);
  if (target.getUTCDay() !== 4) {
    target.setUTCMonth(0, 1 + ((4 - target.getUTCDay()) + 7) % 7);
  }
  const weekNum = 1 + Math.ceil((firstThursday - target.valueOf()) / 604800000);
  return `W${String(weekNum).padStart(2, "0")}`;
}

function formatKstDot(date: Date): string {
  const kstMs = date.getTime() + 9 * 60 * 60 * 1000;
  const k = new Date(kstMs);
  return `${k.getUTCFullYear()}.${String(k.getUTCMonth() + 1).padStart(2, "0")}.${String(k.getUTCDate()).padStart(2, "0")}`;
}

const newestDate = allBriefings[0]?.data.published_at ?? new Date();
const issueWeek = isoWeekNumber(newestDate);
const issueDate = formatKstDot(newestDate);
---

<Base title="YouTube Briefing" activeTab="recent" issueWeek={issueWeek} issueDate={issueDate}>
  {
    allBriefings.length === 0 ? (
      <main id="main"><EmptyState /></main>
    ) : (
      <>
        <div class="intro" data-intro>
          <p>
            <b>7개 경제·시사 유튜브 + 네이버 블로그</b>를 매일 아침 AI가 자동 요약합니다.
          </p>
          <button type="button" aria-label="소개 닫기" data-dismiss-intro>×</button>
        </div>

        <ChannelFilter channels={channelOrder} zeroCountSlugs={zeroCountSlugs} />

        <main id="main">
          <h1 class="visually-hidden">최신 브리핑</h1>

          <div class="unread-ribbon" role="status" aria-live="polite" data-unread-ribbon>
            총 {allBriefings.length}건의 브리핑
          </div>

          {dateGroups.map((group) => (
            <section class="date-group" data-date={group.dateStr}>
              <h2 class="date-header">
                <span class="date-label">{group.dateStr}</span>
                <span class="date-weekday">{group.weekday}요일</span>
                <span class="date-count">{group.briefings.length}건</span>
              </h2>
              {group.briefings.map((b: BriefingEntry) => <BriefingCard briefing={b} />)}
            </section>
          ))}

          <nav class="pagination" aria-label="페이지 네비게이션" data-pagination>
            <button type="button" data-prev disabled>← 이전</button>
            <span class="page-info" data-page-info></span>
            <button type="button" data-next>다음 →</button>
          </nav>
        </main>
      </>
    )
  }
</Base>

<script>
  (() => {
    const ITEMS_PER_PAGE = 10;
    let currentPage = 1;
    let filteredCards: HTMLElement[] = [];
    let activeChannel = "all";

    const allCards = Array.from(document.querySelectorAll<HTMLElement>("article.briefing"));
    const allGroups = Array.from(document.querySelectorAll<HTMLElement>(".date-group"));
    const prevBtn = document.querySelector<HTMLButtonElement>("[data-prev]");
    const nextBtn = document.querySelector<HTMLButtonElement>("[data-next]");
    const pageInfo = document.querySelector<HTMLElement>("[data-page-info]");
    const ribbon = document.querySelector<HTMLElement>("[data-unread-ribbon]");

    function getFilteredCards(): HTMLElement[] {
      if (activeChannel === "all") return allCards;
      return allCards.filter((c) => c.dataset.channel === activeChannel);
    }

    function totalPages(): number {
      return Math.max(1, Math.ceil(filteredCards.length / ITEMS_PER_PAGE));
    }

    function render() {
      filteredCards = getFilteredCards();
      const tp = totalPages();
      if (currentPage > tp) currentPage = tp;

      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;
      const visibleSet = new Set(filteredCards.slice(start, end));

      allCards.forEach((c) => { c.style.display = "none"; });
      visibleSet.forEach((c) => { c.style.display = ""; });

      allGroups.forEach((g) => {
        const groupCards = Array.from(g.querySelectorAll<HTMLElement>("article.briefing"));
        const hasVisible = groupCards.some((c) => visibleSet.has(c));
        g.style.display = hasVisible ? "" : "none";
      });

      if (prevBtn) prevBtn.disabled = currentPage <= 1;
      if (nextBtn) nextBtn.disabled = currentPage >= tp;
      if (pageInfo) pageInfo.textContent = `${currentPage} / ${tp}`;

      if (ribbon) {
        ribbon.textContent = activeChannel === "all"
          ? `총 ${filteredCards.length}건의 브리핑`
          : `${filteredCards.length}건의 브리핑`;
      }

      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    prevBtn?.addEventListener("click", () => { currentPage--; render(); });
    nextBtn?.addEventListener("click", () => { currentPage++; render(); });

    const params = new URLSearchParams(window.location.search);
    activeChannel = params.get("channel") || "all";

    document.querySelectorAll<HTMLAnchorElement>("[data-channel-filter] a").forEach((chip) => {
      const isActive = chip.dataset.slug === activeChannel;
      chip.setAttribute("aria-current", isActive ? "page" : "");
      chip.setAttribute("aria-checked", isActive ? "true" : "false");

      chip.addEventListener("click", (e) => {
        e.preventDefault();
        activeChannel = chip.dataset.slug || "all";
        currentPage = 1;
        const url = new URL(window.location.href);
        if (activeChannel === "all") url.searchParams.delete("channel");
        else url.searchParams.set("channel", activeChannel);
        window.history.pushState({}, "", url.toString());

        document.querySelectorAll<HTMLAnchorElement>("[data-channel-filter] a").forEach((c) => {
          const active = c.dataset.slug === activeChannel;
          c.setAttribute("aria-current", active ? "page" : "");
          c.setAttribute("aria-checked", active ? "true" : "false");
        });
        render();
      });
    });

    document.querySelectorAll<HTMLButtonElement>("[data-expand-button]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const article = btn.closest<HTMLElement>("article.briefing");
        if (!article) return;
        const expanded = article.dataset.expanded === "true";
        article.dataset.expanded = expanded ? "false" : "true";
        btn.setAttribute("aria-expanded", expanded ? "false" : "true");
        btn.textContent = expanded ? "펼쳐보기" : "접기";
      });
    });

    const intro = document.querySelector<HTMLElement>("[data-intro]");
    if (intro && localStorage.getItem("yb-intro-dismissed") === "true") intro.remove();
    document.querySelector<HTMLButtonElement>("[data-dismiss-intro]")?.addEventListener("click", () => {
      intro?.remove();
      localStorage.setItem("yb-intro-dismissed", "true");
    });

    render();
  })();
</script>
