---
import "../styles/global.css";

interface Props {
  title: string;
  activeTab: "recent" | "archive";
  issueWeek: string;
  issueDate: string;
}

const { title, activeTab, issueWeek, issueDate } = Astro.props;

function weekdayKor(dateStr: string): string {
  const [y, m, d] = dateStr.split(".").map(Number);
  if (!y || !m || !d) return "";
  const date = new Date(Date.UTC(y, m - 1, d));
  const korDays = ["SUN", "MON", "TUE", "WED", "THU", "FRI", "SAT"];
  return korDays[date.getUTCDay()] ?? "";
}

const weekday = weekdayKor(issueDate);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content="한국 경제·시사 유튜브 7개 채널과 블로그를 매일 아침 AI 심층 요약" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link
      rel="preload"
      href={`${base}/fonts/Paperlogy-5Medium.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={`${base}/fonts/Paperlogy-9Black.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('yb-theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>

    <div class="shell">
      <div class="wrap">
        <header class="masthead">
          <div class="brand">
            <a href={`${base}/`}>
              <div class="mark">YOUTUBE BRIEFING</div>
              <div class="issue-line">{issueDate} · {weekday}</div>
            </a>
          </div>
          <div class="masthead-right">
            <button type="button" class="theme-toggle" aria-label="다크모드 전환" data-theme-toggle>
              <span class="theme-icon-light">☀️</span>
              <span class="theme-icon-dark">🌙</span>
            </button>
            <nav class="tabs" aria-label="주 메뉴">
              <a href={`${base}/`} aria-current={activeTab === "recent" ? "page" : undefined}>최근</a>
              <a href={`${base}/archive`} aria-current={activeTab === "archive" ? "page" : undefined}>아카이브</a>
            </nav>
          </div>
        </header>

        <slot />
      </div>
    </div>

    <script is:inline>
      (function() {
        var btn = document.querySelector('[data-theme-toggle]');
        if (!btn) return;
        btn.addEventListener('click', function() {
          var html = document.documentElement;
          var isDark = html.getAttribute('data-theme') === 'dark';
          if (isDark) {
            html.removeAttribute('data-theme');
            localStorage.setItem('yb-theme', 'light');
          } else {
            html.setAttribute('data-theme', 'dark');
            localStorage.setItem('yb-theme', 'dark');
          }
        });
      })();
    </script>
  </body>
</html>
